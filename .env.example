# =====================================================================
# Post-In't — environment variables
# Copy this file to .env.local for local development.
# All variables are OPTIONAL: the app degrades gracefully without them.
# =====================================================================

# ----- Google OAuth (Calendar + Drive sync + email) -----
# Required to enable: "Link your account", Today panel, Drive sync,
# carousel "Send to Calendar".
# Get these at: https://console.cloud.google.com/apis/credentials
# In Google Cloud Console register both redirect URIs:
#   http://localhost:3000/api/auth/google/callback
#   https://<your-deployment>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional override — by default the redirect URI is derived from the
# request URL, which works for both localhost and Vercel previews.
# GOOGLE_REDIRECT_URI=

# ----- LLM auto-tagging (easy / medium / hard) -----
# Pick ONE provider. Without either, a keyword heuristic is used.
#
# Groq (recommended — free tier, very fast):
# https://console.groq.com
GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant

# Hugging Face Inference (alternative — free tier with rate limits):
# https://huggingface.co/settings/tokens
# HF_API_KEY=
# HF_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# ----- Persistent share-store (public posit links) -----
# Without these, shared links live in /tmp (dev) or memory (Vercel) and
# disappear on cold start. For production set up Upstash Redis (free tier):
# https://upstash.com → create a Redis database → "REST API" tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
